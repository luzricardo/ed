{
  "name": "data-eng-dbt",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "initializeCommand": "bash -lc 'mkdir -p \"$HOME/.aws\"'",
  "remoteUser": "dataeng",
  "updateRemoteUserUID": true,
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "postStartCommand": "bash .devcontainer/post-start.sh",
  "forwardPorts": [
    18080,
    8080
  ],
  "portsAttributes": {
    "18080": {
      "label": "Spark History Server",
      "onAutoForward": "notify"
    },
    "8080": {
      "label": "Airflow Webserver",
      "onAutoForward": "notify"
    }
  },
  "mounts": [
    "source=${localEnv:HOME}/.aws,target=/home/dataeng/.aws,type=bind,readonly"
  ],
  "containerEnv": {
    "AIRFLOW__CORE__DAGS_FOLDER": "/workspaces/dbt/dags"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "dbt-labs.dbt-power-user",
        "redhat.vscode-yaml",
        "charliermarsh.ruff"
      ]
    }
  }
}
